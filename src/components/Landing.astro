---
/**
 * Homepage — built to be living proof of the Design Field Guide, not a docs page.
 *
 * Design Field Guide / Field Card / Field Manual, applied to our own front door:
 *  - Move 0 — start with the people: the hero leads with the builder and their
 *    community, and the illustration literally shows real people (an elder, a
 *    child, a wheelchair user, a headscarf) — "everyone's invited" made visible.
 *  - Move 1 — one obvious thing: a single primary action (Open the Build Studio).
 *  - Move 2 — less, but better: roomy, restrained; substance over fragments.
 *  - Move 3 — decide once: every colour, space, radius, motion is a token.
 *  - Move 5 — smooth the path: the page reads as one narrative — who you are →
 *    how it works → why you can do this → why you can trust it → start.
 *  - Voice: the way a trusted neighbour would say it. Not a robot, not hype.
 *  - All inline SVG (themeable via tokens, no web fonts, no deps, no trackers).
 */
---

<style is:global>
  /* Splash home only (these rules ship with <Landing>, which renders just on /).
     The visible page heading is the hero headline below; keep Starlight's
     PageTitle as the skip-link target (#_top) but collapse its panel so the home
     page reads as a landing, not a docs article with a title + hairline divider. */
  .main-pane > main > .content-panel:first-child { padding: 0; border: 0; }
  .main-pane > main > .content-panel:first-child h1#_top {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0;
  }
  .main-pane > main > .content-panel + .content-panel { border-top: 0; }
  /* Let the landing govern its own width instead of the narrow docs measure. */
  .main-pane > main > .content-panel .sl-container { max-width: none; }
  /* A landing front door, not a docs search page: hide the header search box on
     home (search stays available on every other page, and via Ctrl/Cmd-K here). */
  .header button[data-open-modal] { display: none; }
</style>

<div class="wcb-landing">
  {/* Structured data so agents + crawlers understand the product (Field Manual §5). */}
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'We Can Just Build Things',
    url: 'https://wecanjustbuildthings.dev',
    description:
      'A verified, values-enforced catalog and guided build flow for shipping community tools with AI agents — never on Meta, OpenAI, or xAI.',
  })} />

  {/* ===================== HERO — start with the people ===================== */}
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero-copy">
      <p class="eyebrow">For people who know their community — not how to code</p>
      <h1 id="hero-title">We can just build things —<br /><span class="accent">for the people who need them.</span></h1>
      <p class="lead">
        Tell the Build Studio what your community needs, the way you'd explain it
        to a neighbour. An AI agent builds it on foundations we've already checked
        and locked to your values — never Meta, OpenAI, or xAI.
        <b>You bring the wisdom. It brings the hands.</b>
      </p>
      <div class="actions">
        <a class="btn btn-primary" href="/build/">
          Open the Build Studio
          <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <a class="btn btn-quiet" href="#how">See how it works</a>
      </div>
      <ul class="trust">
        <li><span class="dot" aria-hidden="true">◆</span> No Meta · OpenAI · xAI</li>
        <li><span class="dot" aria-hidden="true">✓</span> Every tool license-checked at a real commit</li>
        <li><span class="dot" aria-hidden="true">★</span> 1,300+ tools, already vetted</li>
        <li><span class="dot" aria-hidden="true">♥</span> Built with communities, to last</li>
      </ul>
    </div>

    <div class="hero-art" aria-hidden="true">
      <svg viewBox="0 0 520 440" role="img" xmlns="http://www.w3.org/2000/svg">
        <title>A community building something together on a solid foundation</title>
        {/* soft warm depth */}
        <defs>
          <radialGradient id="glowA" cx="30%" cy="22%" r="60%">
            <stop offset="0%" stop-color="var(--md-sys-color-primary)" stop-opacity="0.30"/>
            <stop offset="100%" stop-color="var(--md-sys-color-primary)" stop-opacity="0"/>
          </radialGradient>
          <radialGradient id="glowB" cx="82%" cy="40%" r="55%">
            <stop offset="0%" stop-color="var(--md-sys-color-tertiary)" stop-opacity="0.28"/>
            <stop offset="100%" stop-color="var(--md-sys-color-tertiary)" stop-opacity="0"/>
          </radialGradient>
        </defs>
        <rect x="0" y="0" width="520" height="440" rx="28" fill="var(--md-sys-color-surface-container)"/>
        <rect x="0" y="0" width="520" height="440" rx="28" fill="url(#glowA)"/>
        <rect x="0" y="0" width="520" height="440" rx="28" fill="url(#glowB)"/>

        {/* network of connections — freedom-tech lineage */}
        <g stroke="var(--md-sys-color-primary)" stroke-width="2" stroke-linecap="round" opacity="0.55" fill="none">
          <path d="M150 150 L250 96"/>
          <path d="M250 96 L360 140"/>
          <path d="M150 150 L300 196"/>
          <path d="M360 140 L300 196"/>
          <path d="M120 250 L150 150"/>
          <path d="M300 196 L360 250"/>
        </g>

        {/* the thing being built — rounded blocks assembling */}
        <g class="float">
          <rect x="216" y="64" width="64" height="64" rx="16" fill="var(--md-sys-color-primary)"/>
          <rect x="232" y="84" width="14" height="14" rx="4" fill="var(--md-sys-color-on-primary)" opacity="0.85"/>
          <rect x="252" y="84" width="14" height="14" rx="4" fill="var(--md-sys-color-on-primary)" opacity="0.85"/>
        </g>
        <rect x="116" y="118" width="58" height="58" rx="15" fill="var(--md-sys-color-tertiary)"/>
        <rect x="330" y="108" width="58" height="58" rx="15" fill="var(--md-sys-color-secondary)"/>
        <rect x="266" y="166" width="62" height="62" rx="16" fill="var(--md-sys-color-primary-container)" stroke="var(--md-sys-color-primary)" stroke-width="2"/>
        {/* a block still floating into place + spark */}
        <g class="float2">
          <rect x="372" y="186" width="40" height="40" rx="12" fill="var(--md-sys-color-tertiary)" opacity="0.85"/>
          <path d="M150 92 l4 10 10 4 -10 4 -4 10 -4 -10 -10 -4 10 -4 z" fill="var(--md-sys-color-primary)"/>
        </g>

        {/* connection nodes */}
        <g fill="var(--md-sys-color-primary)">
          <circle cx="150" cy="150" r="5"/>
          <circle cx="250" cy="96" r="5"/>
          <circle cx="360" cy="140" r="5"/>
          <circle cx="300" cy="196" r="5"/>
        </g>

        {/* the verified foundation everything stands on */}
        <rect x="40" y="356" width="440" height="40" rx="20" fill="var(--md-sys-color-primary-container)"/>
        <g transform="translate(64 360)" fill="none" stroke="var(--md-sys-color-on-primary-container)" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="16" r="11" stroke-opacity="0.9"/>
          <path d="M6 16 l4 4 6 -8"/>
        </g>
        <text x="92" y="381" fill="var(--md-sys-color-on-primary-container)" font-size="14" font-weight="700" font-family="inherit">verified, values-locked foundation</text>

        {/* the people — different ages, bodies, ways of being. Everyone's invited. */}
        {/* 1 · the director: arm raised toward what's being built */}
        <g>
          <path d="M86 356 q0 -34 22 -34 q22 0 22 34 z" fill="var(--md-sys-color-primary)"/>
          <path d="M108 322 l16 -20" stroke="var(--md-sys-color-primary)" stroke-width="9" stroke-linecap="round"/>
          <circle cx="108" cy="300" r="13" fill="var(--md-sys-color-primary)"/>
        </g>
        {/* 2 · a child, shorter */}
        <g>
          <path d="M150 356 q0 -24 15 -24 q15 0 15 24 z" fill="var(--md-sys-color-tertiary)"/>
          <circle cx="165" cy="324" r="10" fill="var(--md-sys-color-tertiary)"/>
        </g>
        {/* 3 · an elder, with a cane */}
        <g>
          <path d="M206 356 q0 -32 19 -32 q19 0 19 32 z" fill="var(--md-sys-color-secondary)"/>
          <circle cx="225" cy="318" r="12" fill="var(--md-sys-color-secondary)"/>
          <path d="M246 330 l0 26" stroke="var(--md-sys-color-on-surface-variant)" stroke-width="3" stroke-linecap="round"/>
        </g>
        {/* 4 · a person using a wheelchair */}
        <g>
          <path d="M286 340 q0 -30 18 -30 q18 0 18 22 l0 8 z" fill="var(--md-sys-color-primary)"/>
          <circle cx="304" cy="304" r="12" fill="var(--md-sys-color-primary)"/>
          <circle cx="300" cy="350" r="16" fill="none" stroke="var(--md-sys-color-on-surface-variant)" stroke-width="3"/>
          <path d="M286 340 l28 0" stroke="var(--md-sys-color-on-surface-variant)" stroke-width="3" stroke-linecap="round"/>
        </g>
        {/* 5 · a person wearing a headscarf */}
        <g>
          <path d="M356 356 q0 -32 19 -32 q19 0 19 32 z" fill="var(--md-sys-color-tertiary)"/>
          <path d="M362 316 a13 13 0 0 1 26 0 q0 14 -13 14 q-13 0 -13 -14 z" fill="var(--md-sys-color-tertiary)"/>
        </g>
        {/* 6 · another adult */}
        <g>
          <path d="M414 356 q0 -34 21 -34 q21 0 21 34 z" fill="var(--md-sys-color-secondary)"/>
          <circle cx="435" cy="320" r="13" fill="var(--md-sys-color-secondary)"/>
        </g>
      </svg>
    </div>
  </section>

  {/* ===================== HOW IT WORKS — smooth the path ===================== */}
  <section class="how" id="how" aria-labelledby="how-title">
    <header class="band-head">
      <h2 id="how-title">How it works</h2>
      <p>Three steps, no jargon — and you stay in charge the whole way.</p>
    </header>

    <ol class="steps">
      <li class="step">
        <span class="step-art">
          <svg viewBox="0 0 48 48" aria-hidden="true" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <rect x="6" y="9" width="36" height="26" rx="9" fill="var(--md-sys-color-primary-container)"/>
            <path d="M16 25h16M16 19h12" stroke="var(--md-sys-color-on-primary-container)" stroke-width="3"/>
            <path d="M18 35l-4 6v-6z" fill="var(--md-sys-color-primary-container)"/>
          </svg>
        </span>
        <h3><span class="num">1</span> Say it in plain words</h3>
        <p>Describe what your community needs to do — talk like you'd talk to a friend who's good with computers. No tech vocabulary required.</p>
      </li>
      <li class="step">
        <span class="step-art">
          <svg viewBox="0 0 48 48" aria-hidden="true" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="7" width="30" height="34" rx="7" fill="var(--md-sys-color-tertiary-container)"/>
            <path d="M16 16h16M16 23h16M16 30h10" stroke="var(--md-sys-color-on-tertiary-container)" stroke-width="3"/>
            <circle cx="33" cy="33" r="9" fill="var(--md-sys-color-tertiary)"/>
            <path d="M29.5 33l2.5 2.5 4.5-5" stroke="var(--md-sys-color-on-tertiary)" stroke-width="2.6"/>
          </svg>
        </span>
        <h3><span class="num">2</span> Get a plan you can read</h3>
        <p>The Studio hands back the exact tools and a plan in plain language — so you can see it, question it, and change it before anything is built.</p>
      </li>
      <li class="step">
        <span class="step-art">
          <svg viewBox="0 0 48 48" aria-hidden="true" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <rect x="7" y="20" width="34" height="9" rx="4.5" fill="var(--md-sys-color-primary-container)"/>
            <rect x="13" y="9" width="10" height="10" rx="3" fill="var(--md-sys-color-primary)"/>
            <rect x="25" y="9" width="10" height="10" rx="3" fill="var(--md-sys-color-tertiary)"/>
            <circle cx="16" cy="37" r="6" fill="var(--md-sys-color-secondary)"/>
            <circle cx="32" cy="37" r="6" fill="var(--md-sys-color-primary)"/>
          </svg>
        </span>
        <h3><span class="num">3</span> Hand it to your agent</h3>
        <p>Your AI agent does the building on a verified, values-locked foundation. You stay the director, start to finish.</p>
      </li>
    </ol>
  </section>

  {/* ===================== THE MENTOR TRUTH — the soul ===================== */}
  <section class="mentor" aria-labelledby="mentor-title">
    <div class="mentor-inner">
      <h2 id="mentor-title">You don't need to be a developer. Or a designer.</h2>
      <p>
        You have something rarer: you know your people — the elders, the kids, the
        crew, the folks on five-year-old phones in bright sun. That knowledge is the
        most important design input there is, and no big-tech default has it.
        The Studio carries the technical rules and the accessibility floor for you.
        You bring the judgment.
      </p>
      <blockquote>
        You bring the wisdom. The agent brings the hands.
        <strong>Together, that's how someone who isn't a developer ships work their community will love.</strong>
      </blockquote>
      <a class="link-arrow" href="/guides/design-for-your-community/">
        Read the Design Field Guide
        <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  </section>

  {/* ===================== WHY YOU CAN TRUST IT ===================== */}
  <section class="trust-section" aria-labelledby="trust-title">
    <header class="band-head">
      <h2 id="trust-title">Built to be trusted — and to last</h2>
      <p>Not promises. Things you can check yourself.</p>
    </header>

    <div class="cards">
      <article class="tcard">
        <span class="tcard-ico ico-shield" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="m9 12 2 2 4-4"/></svg>
        </span>
        <h3>Values, enforced — not promised</h3>
        <p>Nothing owned by Meta, OpenAI, or xAI. It's checked on every single build, automatically. Receipts included.</p>
      </article>
      <article class="tcard">
        <span class="tcard-ico ico-check" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="m8 12 3 3 5-6"/></svg>
        </span>
        <h3>Trust you can verify yourself</h3>
        <p>Every tool's license is checked at a real commit — not taken on faith. The proof travels with it.</p>
      </article>
      <article class="tcard">
        <span class="tcard-ico ico-welcome" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3.2"/><path d="M3.5 20a5.5 5.5 0 0 1 11 0"/><path d="M16 7.5a3 3 0 0 1 0 6M17.5 20a5.5 5.5 0 0 0-3-4.9"/></svg>
        </span>
        <h3>Everyone's invited</h3>
        <p>Every build starts at the WCAG 2.2 AA floor — readable, tappable, screen-reader friendly — so no one in your community is left out.</p>
      </article>
      <article class="tcard">
        <span class="tcard-ico ico-roots" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v8"/><path d="M12 11c0 4-3 6-7 7M12 11c0 4 3 6 7 7"/><circle cx="12" cy="11" r="2.4"/></svg>
        </span>
        <h3>Made to outlive any maintainer</h3>
        <p>Open methodology, open catalog, open enforcement — built with communities, so it keeps working when people move on.</p>
      </article>
    </div>
  </section>

  {/* ===================== CLOSING — clear next step ===================== */}
  <section class="closing" aria-label="Where to go next">
    <div class="paths">
      <a class="path" href="/start/">
        <span class="path-kicker">New here?</span>
        <span class="path-main">Start in 3 minutes</span>
        <span class="path-sub">A gentle walk from idea to your first build.</span>
      </a>
      <a class="path" href="/catalog/">
        <span class="path-kicker">Already ship?</span>
        <span class="path-main">Browse 1,300+ vetted tools</span>
        <span class="path-sub">Every one license-checked and values-clean.</span>
      </a>
    </div>
    <p class="signoff">We can just build things — <span class="accent">well.</span></p>
  </section>
</div>

<style>
  .wcb-landing {
    --maxw: 64rem;
    max-width: var(--maxw);
    margin-inline: auto;
    /* generous rhythm between movements of the page (Move 2: room to breathe) */
    display: flex;
    flex-direction: column;
    gap: clamp(var(--wcb-space-xl), 8vw, 5.5rem);
  }
  .accent { color: var(--sl-color-text-accent); }

  /* ---------- HERO ---------- */
  .hero {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    align-items: center;
    gap: clamp(var(--wcb-space-lg), 4vw, var(--wcb-space-xl));
    padding-top: clamp(var(--wcb-space-md), 4vw, var(--wcb-space-xl));
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: var(--wcb-text-sm);
    font-weight: 700;
    color: var(--sl-color-text-accent);
    margin: 0 0 var(--wcb-space-xs);
  }
  .hero h1 {
    font-size: clamp(2.1rem, 5.2vw, 3.4rem);
    line-height: 1.06;
    letter-spacing: -0.02em;
    font-weight: 800;
    margin: 0;
  }
  .lead {
    font-size: clamp(1.05rem, 1.6vw, 1.2rem);
    line-height: 1.6;
    color: var(--sl-color-text);
    max-width: 34rem;
    margin: var(--wcb-space-md) 0 0;
  }
  .lead b { color: var(--sl-color-text-accent); font-weight: 700; }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--wcb-space-sm);
    margin-top: var(--wcb-space-lg);
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--wcb-space-2xs);
    min-height: 2.875rem; /* 46px — comfortable tap target */
    padding: 0 var(--wcb-space-md);
    border-radius: var(--wcb-radius-pill);
    font-weight: 700;
    font-size: var(--wcb-text-base);
    text-decoration: none;
    transition:
      transform var(--wcb-motion-fast) var(--wcb-easing-standard),
      box-shadow var(--wcb-motion-fast) var(--wcb-easing-standard),
      background var(--wcb-motion-fast) var(--wcb-easing-standard);
  }
  .btn svg { width: 1.1rem; height: 1.1rem; }
  .btn-primary {
    background: var(--sl-color-accent);
    color: var(--wcb-on-accent);
    box-shadow: var(--wcb-shadow-1);
  }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: var(--wcb-shadow-2); }
  .btn-primary:active { transform: translateY(0); box-shadow: var(--wcb-shadow-1); }
  .btn-quiet {
    color: var(--sl-color-text);
    border: 1px solid color-mix(in srgb, var(--sl-color-gray-4) 55%, transparent);
    background: transparent;
  }
  .btn-quiet:hover {
    background: color-mix(in srgb, var(--sl-color-accent) 12%, transparent);
    border-color: color-mix(in srgb, var(--sl-color-accent) 50%, transparent);
  }

  .trust {
    list-style: none;
    margin: var(--wcb-space-lg) 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--wcb-space-2xs) var(--wcb-space-md);
    font-size: var(--wcb-text-sm);
    color: var(--sl-color-gray-2);
  }
  .trust li { display: inline-flex; align-items: center; gap: var(--wcb-space-3xs); font-weight: 600; }
  .trust .dot { color: var(--sl-color-text-accent); }

  .hero-art svg { width: 100%; height: auto; display: block; filter: drop-shadow(var(--wcb-shadow-1)); }
  .float { animation: floatY 6s var(--wcb-easing-standard) infinite; transform-origin: center; }
  .float2 { animation: floatY 5s var(--wcb-easing-standard) infinite; animation-delay: -2s; }
  @keyframes floatY { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-7px); } }

  /* ---------- shared band heading ---------- */
  .band-head { text-align: center; max-width: 40rem; margin-inline: auto; }
  .band-head h2 {
    font-size: clamp(1.6rem, 3vw, 2.1rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    font-weight: 800;
    margin: 0;
    /* override the docs-style top rule Starlight gives h2 */
    border: 0;
    padding: 0;
  }
  .band-head p { margin: var(--wcb-space-2xs) 0 0; color: var(--sl-color-gray-2); font-size: var(--wcb-text-lg); }

  /* ---------- HOW IT WORKS ---------- */
  .steps {
    list-style: none;
    margin: var(--wcb-space-xl) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--wcb-space-md);
    counter-reset: step;
    position: relative;
  }
  /* the connecting thread of the journey */
  .steps::before {
    content: "";
    position: absolute;
    top: 1.9rem;
    left: 16%;
    right: 16%;
    height: 2px;
    background: repeating-linear-gradient(90deg, color-mix(in srgb, var(--sl-color-accent) 55%, transparent) 0 8px, transparent 8px 16px);
    z-index: 0;
  }
  .step { position: relative; z-index: 1; text-align: center; padding: 0 var(--wcb-space-2xs); }
  .step-art {
    display: inline-flex;
    width: 3.75rem;
    height: 3.75rem;
    align-items: center;
    justify-content: center;
    border-radius: var(--wcb-radius-md);
    background: var(--md-sys-color-surface-container-high);
    border: 1px solid color-mix(in srgb, var(--sl-color-gray-4) 40%, transparent);
    box-shadow: var(--wcb-shadow-1);
  }
  .step-art svg { width: 2.25rem; height: 2.25rem; }
  .step h3 {
    margin: var(--wcb-space-sm) 0 var(--wcb-space-2xs);
    font-size: var(--wcb-text-lg);
    font-weight: 700;
    display: flex;
    gap: var(--wcb-space-2xs);
    align-items: baseline;
    justify-content: center;
  }
  .step h3 .num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    flex: 0 0 auto;
    border-radius: var(--wcb-radius-pill);
    background: var(--sl-color-accent);
    color: var(--wcb-on-accent);
    font-size: var(--wcb-text-sm);
    font-weight: 800;
    align-self: center;
  }
