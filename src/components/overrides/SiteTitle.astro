---
/**
 * SiteTitle override — bespoke brand lockup (replaces Starlight's default).
 * The green "build plate" mark + the wordmark set in the display face, with a
 * single marigold register tick as the seed of the signature. Imports the logo
 * asset directly (no Starlight virtual modules) and keeps the i18n href.
 */
import logo from '../../assets/logo.svg';
const { siteTitleHref, siteTitle } = Astro.locals.starlightRoute;
---

<a href={siteTitleHref} class="wcb-brand sl-flex" translate="no">
  <span class="wcb-brand__mark">
    <img src={logo.src} width={logo.width} height={logo.height} alt="" />
  </span>
  <span class="wcb-brand__word">{siteTitle}</span>
</a>

<style>
  .wcb-brand {
    align-items: center;
    gap: var(--space-2xs);
    text-decoration: none;
    min-width: 0;
    white-space: nowrap;
  }
  .wcb-brand__mark {
    position: relative;
    display: inline-flex;
    flex: 0 0 auto;
  }
  .wcb-brand__mark img {
    height: calc(var(--sl-nav-height) - 2 * var(--sl-nav-pad-y));
    width: auto;
    border-radius: var(--radius-sm);
    display: block;
  }
  /* the marigold register tick — the one warm accent in the chrome */
  .wcb-brand__mark::after {
    content: "";
    position: absolute;
    inset-block-end: -3px;
    inset-inline-start: 0;
    width: 60%;
    height: 3px;
    border-radius: 999px;
    background: var(--signal);
  }
  .wcb-brand__word {
    font-family: var(--font-display);
    font-weight: var(--weight-black);
    letter-spacing: -0.02em;
    font-size: var(--step-1);
    line-height: 1;
    color: var(--ink);
    overflow: hidden;
    text-overflow: ellipsis;
  }
  @media (max-width: 50rem) {
    .wcb-brand__word { font-size: var(--step-0); }
  }
</style>
